@article{lee_pulse_2024,
	title = {Pulse shape discrimination in an organic scintillation phoswich detector using machine learning techniques},
	volume = {Volume 12 - 2024},
	issn = {2296-424X},
	url = {https://www.frontiersin.org/journals/physics/articles/10.3389/fphy.2024.1361608},
	abstract = {We developed machine learning algorithms for distinguishing scintillation signals from a plasticliquid coupled detector known as a phoswich. The challenge lies in discriminating signals from organic scintillators with similar shapes and short decay times. Using a single-readout phoswich detector, we successfully identified γ radiation signals from two scintillating components. Our Boosted Decision Tree algorithm demonstrated a maximum discrimination power of 3.02 ± 0.85 standard deviation in the 950 {keV} region, providing an efficient solution for self-shielding and enhancing radiation detection capabilities.},
	journaltitle = {Frontiers in Physics},
	shortjournal = {Frontiers in Physics},
	author = {Lee, Yujin and Kim, Jinyoung and Koh, Byoung-cheol and Yoon, Young Soo and Ha, Chang Hyon},
	date = {2024},
}


@article{di_fulvio_passive_2017,
	title = {Passive assay of plutonium metal plates using a fast-neutron multiplicity counter},
	volume = {855},
	issn = {0168-9002},
	url = {https://www.sciencedirect.com/science/article/pii/S0168900217303066},
	doi = {10.1016/j.nima.2017.02.082},
	abstract = {We developed a fast-neutron multiplicity counter based on organic scintillators ({EJ}-309 liquid and stilbene). The system detects correlated photon and neutron multiplets emitted by fission reactions, within a gate time of tens of nanoseconds. The system was used at Idaho National Laboratory to assay a variety of plutonium metal plates. A coincidence counting strategy was used to quantify the 240Pu effective mass of the samples. Coincident neutrons, detected within a 40-ns coincidence window, show a monotonic trend, increasing with the 240Pu-effective mass (in this work, we tested the 0.005–0.5kg range). After calibration, the system estimated the 240Pu effective mass of an unknown sample (240Pueff {\textgreater}50g) with an uncertainty lower than 1\% in a 4-min assay time.},
	pages = {92--101},
	journaltitle = {Nuclear Instruments and Methods in Physics Research Section A: Accelerators, Spectrometers, Detectors and Associated Equipment},
	shortjournal = {Nuclear Instruments and Methods in Physics Research Section A: Accelerators, Spectrometers, Detectors and Associated Equipment},
	author = {Di Fulvio, A. and Shin, T. H. and Jordan, T. and Sosa, C. and Ruch, M. L. and Clarke, S. D. and Chichester, D. L. and Pozzi, S. A.},
	urldate = {2026-04-23},
	date = {2017-05-21},
	keywords = {Fast-neutron multiplicity counter, Organic scintillators, Plutonium metal, Safeguards},
}


